---
interface Props {
  title: string;
  description: string;
  imageUrl: string;
  imageAlt: string;
}

const { title, description, imageUrl, imageAlt } = Astro.props;
---

<header class="relative h-[50vh] md:h-[62vh] min-h-105 w-full overflow-hidden">
  <img
    src={imageUrl}
    alt={imageAlt}
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
  />
  <div class="absolute inset-0 bg-slate-950/45"></div>

  <div
    class="relative mx-auto flex h-full w-full max-w-6xl items-end px-6 pb-12 sm:px-8 md:pb-16 lg:px-10"
  >
    <div class="max-w-2xl text-stone-50">
      <h1 class="text-3xl font-semibold sm:text-4xl md:text-5xl lg:text-6xl">
        {title}
      </h1>
      <p
        class="mt-4 max-w-xl text-sm text-stone-100/90 sm:text-base md:text-lg"
      >
        {description}
      </p>
    </div>
  </div>
</header>
