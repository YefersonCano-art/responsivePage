---
interface Props {
  label: string;
  href?: string;
}

const { label, href = "#" } = Astro.props;
---

<a
  href={href}
  class="inline-flex items-center justify-center rounded-full bg-slate-900 px-7 py-3 text-sm font-semibold tracking-wide text-stone-50 transition hover:bg-slate-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-900"
>
  {label}
</a>
