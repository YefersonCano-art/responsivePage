---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<nav class="h-16 w-full bg-slate-900 text-stone-50">
  <div
    class="mx-auto flex h-full w-full max-w-6xl items-center px-6 sm:px-8 lg:px-10"
  >
    <h1 class="text-xl font-semibold sm:text-2xl">{title}</h1>
  </div>
</nav>
